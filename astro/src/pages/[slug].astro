---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import WipeSlider from "../components/WipeSlider.astro";
import { FILMS, type Film } from "../data/studio";

export function getStaticPaths() {
  // Only films with a real internal case study (href "/<slug>") are routed;
  // the rest stay href "#" on the landing until their case study is written.
  return FILMS.filter((f) => f.href.startsWith("/")).map((film) => ({
    params: { slug: film.slug },
    props: { film },
  }));
}

interface Props {
  film: Film;
}
const { film } = Astro.props;

const idx = FILMS.findIndex((f) => f.slug === film.slug);
const next = FILMS[(idx + 1) % FILMS.length];

const meta: [string, string][] = [
  ["Studio role", film.studioRole],
  ["Format", film.studioMeta],
  ["Schedule", film.days],
  ["Capture", film.capture],
];
---

<Base
  title={`${film.title} - Case study · The Studio`}
  description={`${film.studioRole} on ${film.title}, a ${film.kind.toLowerCase()} directed by ${film.director}. By The Studio.`}
>
  <div style="position: relative">
    <Nav crumb={film.title} />

    {/* HERO - full-bleed wipe slider so the grade reveal lands on page load */}
    <section style="position: relative; height: min(720px, 86vh)">
      <WipeSlider src={film.hero} height="100%" vtName={`film-${film.slug}`} corners={false} />
      <div style="position: absolute; left: 48px; bottom: clamp(28px, 6vh, 56px); right: 48px; pointer-events: none">
        <div style="font-size: 13.5px; color: rgba(237,232,221,0.75); margin-bottom: 18px; letter-spacing: 0.04em">
          {film.kind} · Directed by {film.director} · {film.year}
        </div>
        <h1 style="font-size: clamp(64px, 10vw, 132px); font-weight: 600; letter-spacing: -0.045em; line-height: 0.88; margin: 0; color: var(--ink); font-family: var(--font-display)">
          {film.title}.
        </h1>
      </div>
    </section>

    {/* META BAR - what the studio did, at a glance */}
    <section class="section" style="padding: 56px 48px">
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; padding-top: 4px">
        {
          meta.map(([k, v]) => (
            <div>
              <div style="font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--dim); margin-bottom: 10px">{k}</div>
              <div style="font-size: 16px; color: var(--ink); line-height: 1.45">{v}</div>
            </div>
          ))
        }
      </div>
    </section>

    {/* NOTE - colourist's note */}
    <section class="section">
      <div style="display: grid; grid-template-columns: 240px 1fr; gap: 64px">
        <div style="font-size: 13.5px; color: var(--dim); padding-top: 4px">Note</div>
        <p style="font-size: 21px; line-height: 1.6; margin: 0; max-width: 60ch; color: var(--ink)">
          {film.note}
        </p>
      </div>
    </section>

    {/* COMPARISON FRAMES - additional stills, each a wipe slider */}
    <section class="section">
      <div class="section-head">
        <h2>Frames.</h2>
        <span class="meta">Drag the line on any frame.</span>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 18px">
        {
          film.stills.map((src, i) => (
            <div>
              <WipeSlider src={src} aspectRatio="16 / 9" />
              <div style="display: flex; justify-content: space-between; margin-top: 10px; font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--dim)">
                <span>Frame {String(i + 1).padStart(2, "0")}</span>
                <span>{film.title}</span>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    {/* DELIVERABLES - quiet list */}
    <section class="section">
      <div style="display: grid; grid-template-columns: 240px 1fr; gap: 64px">
        <div style="font-size: 13.5px; color: var(--dim); padding-top: 4px">Deliverables</div>
        <ul style="margin: 0; padding: 0; list-style: none">
          {
            film.deliverables.map((d, i) => (
              <li
                style={`font-size: 18px; line-height: 1.7; color: var(--ink); padding-bottom: 10px; margin-bottom: 10px; ${i < film.deliverables.length - 1 ? "border-bottom: 1px dashed var(--rule)" : ""}`}
              >
                {d}
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    {/* NEXT CASE STUDY - cinematic teaser */}
    <section style="border-top: 1px solid var(--rule)">
      <a href={next.href} style="display: block">
        <div style="position: relative; height: 380px; overflow: hidden">
          <img
            src={next.hero}
            alt=""
            style="width: 100%; height: 100%; object-fit: cover; filter: brightness(0.55) saturate(0.85)"
          />
          <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.2) 60%, transparent 100%)"></div>
          <div style="position: absolute; left: 48px; bottom: 36px; right: 48px">
            <div style="font-size: 13.5px; color: rgba(237,232,221,0.7); margin-bottom: 14px; letter-spacing: 0.04em">Next case study -</div>
            <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 24px; flex-wrap: wrap">
              <span style="font-size: clamp(40px, 6vw, 76px); font-weight: 500; letter-spacing: -0.035em; line-height: 1.0; color: var(--ink); font-family: var(--font-display)">{next.title}.</span>
              <span style="font-size: 14px; color: var(--ink); border-bottom: 1px solid var(--faint); padding-bottom: 2px">Open →</span>
            </div>
          </div>
        </div>
      </a>
    </section>

    <Footer />
  </div>
</Base>
