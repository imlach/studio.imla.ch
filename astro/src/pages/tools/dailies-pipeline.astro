---
// Detail page for the dailies pipeline - the studio's in-development tool for
// turning shoot media into something searchable. Standalone and linkable so it
// can be cited from an article. Copy is grounded in the tool's own README + architecture notes;
// no GitHub link because the repo is private during development (TOOLS[0].link
// is null on the landing for the same reason).
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { imgSet } from "../../data/studio";

const heroImg = await imgSet("/images/bynow/4.hd.jpg");
const bandImg = await imgSet("/images/sneaker/8.hd.jpg");

const meta: [string, string][] = [
  ["Status", "v0.1 · in development"],
  ["What", "Dailies and search pipeline"],
  ["Stack", "FastAPI · Prefect · Postgres"],
  ["License", "AGPL-3.0-or-later"],
];

// The pipeline, stage by stage. The first five are the v0.1 default chain;
// faces is flow-driven but opt-in per job. Slate, visual
// tags, focus and reconcile come after - see the note under the list.
const stages: { t: string; d: string }[] = [
  { t: "Ingest", d: "Read camera cards and recorder files into a shoot record. One clip per source file, with the basic technical details attached." },
  { t: "Probe", d: "Run ffprobe on each clip for resolution, codec, framerate and embedded timecode. Local, cheap and quick to repeat." },
  { t: "Proxy", d: "Make viewing proxies from the camera originals. FFmpeg handles common codecs; a Resolve seat can take over for RAW formats like X-OCN, ARRIRAW, BRAW and R3D. Unsupported clips are flagged instead of stopping the job." },
  { t: "Sync", d: "Pull audio from picture, then match standalone recorder files by timecode, including the offset of the clip's first frame inside the take." },
  { t: "Transcribe", d: "Run WhisperX so dialogue is timed and searchable. Search for the line, not just the filename." },
  { t: "Faces", d: "Mark who appears in a clip and when, using a person list for that shoot. It works as an opt-in job today, not part of the default run." },
];

// Why HTTP-from-day-one matters, in studio language rather than protocol terms.
const principles: { t: string; d: string }[] = [
  { t: "Works from a browser or script", d: "The same job can be started from a small web UI, a REST call, or an automated trigger. No workstation has to be the one machine that knows how it works." },
  { t: "Backends stay replaceable", d: "WhisperX can be swapped for a managed transcriber. FFmpeg can render most proxies, while Resolve handles the RAW it supports. That choice belongs in config and capability checks, not in a rewrite." },
  { t: "Same build everywhere", d: "The same image runs in docker-compose on a laptop and on the cluster. Different config, same code." },
];

// Roadmap - three horizons, grounded in the orchestrator's own deferral notes
// and open issues: durable runs (no more inline-asyncio), the real render and
// transcribe backends, then the Phase 2 enrichment + vector search.
const roadmap: { when: string; phase: string; title: string; items: string[] }[] = [
  {
    when: "Now",
    phase: "v0.1",
    title: "Working end to end",
    items: [
      "Ingest, probe, proxy, sync and transcribe run as one chain. Faces can be requested per job.",
      "Screenplay parsing creates scene records for the shoot.",
      "Filename and transcript search work on stand-in backends, so local development and CI do not need a GPU.",
    ],
  },
  {
    when: "Next",
    phase: "Phase 1",
    title: "Real backends, durable runs",
    items: [
      "Wire in the FFmpeg renderer and Resolve render seat for production proxy generation, including RAW.",
      "Move to a Prefect server with per-backend work pools, so runs survive restarts and clips fan out in parallel.",
      "Add Alembic migrations and scheduled database backups.",
    ],
  },
  {
    when: "Later",
    phase: "Phase 2",
    title: "Enrichment + search",
    items: [
      "Add slate OCR, visual tags, focus timelines and a reconcile pass against department reports.",
      "Add semantic and face search on pgvector, with a Qdrant offload path if the embedding volume outgrows Postgres.",
      "Open the source under AGPL-3.0 once the tool is past v0.1.",
    ],
  },
];
---

<Base
  title="The dailies pipeline · The Studio"
  description="A per-shoot dailies pipeline: camera originals in, proxies, sync, transcripts and search out. Built by The Studio."
>
  <div style="position: relative">
    <Nav crumb="The dailies pipeline" />

    {/* HERO - full-bleed darkened still, same treatment as the landing tools block */}
    <section style="position: relative; height: min(720px, 86vh); overflow: hidden">
      <img
        src={heroImg.src}
        srcset={heroImg.srcset}
        sizes="100vw"
        width={heroImg.width}
        height={heroImg.height}
        alt=""
        style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; filter: brightness(0.4) saturate(0.55)"
      />
      <div style="position: absolute; inset: 0; background: linear-gradient(160deg, rgba(20,20,22,0.45) 0%, rgba(0,0,0,0.82) 100%)"></div>
      <div class="hero-caption" style="bottom: clamp(28px, 6vh, 56px); pointer-events: none">
        <div style="font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(237,232,221,0.85); margin-bottom: 18px">
          A tool · In development
        </div>
        <h1 style="font-size: clamp(56px, 9vw, 120px); font-weight: 600; letter-spacing: -0.045em; line-height: 0.9; margin: 0; color: var(--ink); font-family: var(--font-display)">
          The dailies pipeline.
        </h1>
        <p style="font-size: clamp(17px, 2.4vw, 22px); color: rgba(237,232,221,0.82); max-width: 60ch; margin: 22px 0 0; line-height: 1.55">
          Camera originals in. Proxies, sync, transcripts and search out.
        </p>
      </div>
    </section>

    {/* META BAR - at a glance, mirrors the case-study layout */}
    <section class="section" style="padding: 56px 48px">
      <div class="meta-grid" style="padding-top: 4px">
        {
          meta.map(([k, v]) => (
            <div>
              <div style="font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--dim); margin-bottom: 10px">{k}</div>
              <div style="font-size: 16px; color: var(--ink); line-height: 1.45">{v}</div>
            </div>
          ))
        }
      </div>
    </section>

    {/* THE PROBLEM - the why, in the studio's voice */}
    <section class="section">
      <div class="label-row">
        <div style="font-size: 13.5px; color: var(--dim); padding-top: 4px">Why</div>
        <div style="max-width: 62ch">
          <p style="font-size: 21px; line-height: 1.6; margin: 0; color: var(--ink)">
            After a shoot, the useful details end up scattered: camera cards, sound rolls, notes, reports, bins, exports. By the time the grade starts, someone is often doing the same search again - the take, the line, the setup, the look.
          </p>
          <p style="font-size: 17px; line-height: 1.65; color: var(--dim); margin: 22px 0 0">
            This is our attempt to keep that work attached to the media. The first version takes camera originals and sound files, makes proxies, syncs audio, transcribes dialogue and indexes the result. Slate OCR, focus notes, visual tags and report reconciliation come after the core run is dependable.
          </p>
        </div>
      </div>
    </section>

    {/* HOW IT WORKS - the stages, as numbered service rows */}
    <section class="section">
      <div class="split-head">
        <div>
          <div style="font-size: 13.5px; color: var(--accent); margin-bottom: 18px; letter-spacing: 0.04em">01 - the pipeline</div>
          <h2 style="font-size: clamp(48px, 6vw, 80px); font-weight: 500; letter-spacing: -0.04em; line-height: 0.92; margin: 0; font-family: var(--font-display)">How it works.</h2>
        </div>
        <div style="padding-top: 14px">
          <p style="font-size: 19px; line-height: 1.65; margin: 0">
            A shoot moves through a chain of repeatable stages. Re-running a job only fills in the work that is missing.
          </p>
          <p style="font-size: 16px; line-height: 1.65; color: var(--dim); margin: 20px 0 0; max-width: 56ch">
            Ingest, probe, proxy, sync and transcribe run end to end today, with face detection available per job. Stand-in backends keep local development and CI simple; production points the same code at the real render and transcription services.
          </p>
        </div>
      </div>

      <div style="border-top: 1px solid var(--rule)">
        {
          stages.map((s, i) => (
            <div class="service-row" style="padding: 24px 0; border-bottom: 1px solid var(--rule)">
              <span style="font-size: clamp(21px, 2.8vw, 26px); font-weight: 500; letter-spacing: -0.015em">{s.t}</span>
              <span style="font-size: 15px; color: var(--dim); line-height: 1.55">{s.d}</span>
              <span class="num" style="font-size: 13px; color: var(--faint); text-align: right">0{i + 1}</span>
            </div>
          ))
        }
      </div>

      <div style="padding: 28px 0 0">
        <p style="font-size: 15px; line-height: 1.7; color: var(--faint); margin: 0; max-width: 70ch">
          Slate, visual tags, focus and reconcile tables are in the schema, but are not driven by a flow yet. They are the next layer, not part of the default run.
        </p>
      </div>
    </section>

    {/* HAND-OFF - metadata goes back into the NLEs, rather than another app */}
    <section class="section">
      <div class="label-row">
        <div style="font-size: 13.5px; color: var(--dim); padding-top: 4px">Hand-off</div>
        <div style="max-width: 62ch">
          <p style="font-size: 21px; line-height: 1.6; margin: 0; color: var(--ink)">
            The point is not to make editors live in another tool. The metadata should come back into the edit and the grade as bin columns, markers and sidecars.
          </p>
          <ul style="margin: 26px 0 0; padding: 0; list-style: none">
            <li style="font-size: 16px; line-height: 1.6; color: var(--dim); padding-bottom: 13px; margin-bottom: 13px; border-bottom: 1px dashed var(--rule)">
              <span style="color: var(--ink)">Avid Media Composer</span> - ALE, the standard dailies log: scene, shot and take straight into the bin.
            </li>
            <li style="font-size: 16px; line-height: 1.6; color: var(--dim); padding-bottom: 13px; margin-bottom: 13px; border-bottom: 1px dashed var(--rule)">
              <span style="color: var(--ink)">DaVinci Resolve</span> - metadata CSV today; transcript, face and focus markers pushed to the render seat next.
            </li>
            <li style="font-size: 16px; line-height: 1.6; color: var(--dim)">
              <span style="color: var(--ink)">Premiere Pro</span> - XMP sidecars, on the way.
            </li>
          </ul>
          <p style="font-size: 15px; line-height: 1.65; color: var(--dim); margin: 24px 0 0">
            Clips are keyed by source file, so the hand-off stays close to the way assistants already relink and rebuild bins.
          </p>
        </div>
      </div>
    </section>

    {/* BAND - a darkened still to break the page, cinematic */}
    <section style="position: relative; overflow: hidden; height: 340px; border-top: 1px solid var(--rule)">
      <img
        src={bandImg.src}
        srcset={bandImg.srcset}
        sizes="100vw"
        width={bandImg.width}
        height={bandImg.height}
        alt=""
        style="width: 100%; height: 100%; object-fit: cover; filter: brightness(0.45) saturate(0.6)"
      />
      <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.25) 60%, transparent 100%)"></div>
      <div class="hero-caption" style="bottom: 32px">
        <div style="font-size: 17px; line-height: 1.6; color: rgba(237,232,221,0.9); max-width: 64ch">
          The take is usually there. The hard part is finding it after the notes, exports and bins have drifted apart.
        </div>
      </div>
    </section>

    {/* HOW IT'S BUILT - the principles that keep it portable */}
    <section class="section">
      <div class="split-head">
        <div>
          <div style="font-size: 13.5px; color: var(--accent); margin-bottom: 18px; letter-spacing: 0.04em">02 - the shape of it</div>
          <h2 style="font-size: clamp(48px, 6vw, 80px); font-weight: 500; letter-spacing: -0.04em; line-height: 0.92; margin: 0; font-family: var(--font-display)">How it's built.</h2>
        </div>
        <div style="padding-top: 14px">
          <p style="font-size: 19px; line-height: 1.65; margin: 0">
            A small orchestration service talks over HTTP to the heavier render and transcription services.
          </p>
          <p style="font-size: 16px; line-height: 1.65; color: var(--dim); margin: 20px 0 0; max-width: 56ch">
            Transcription and proxy rendering run outside the core app. Rendering is routed per clip: FFmpeg for common codecs, Resolve for RAW formats FFmpeg cannot decode cleanly. The core asks for a connector by type; config picks the implementation.
          </p>
        </div>
      </div>

      <div style="border-top: 1px solid var(--rule)">
        {
          principles.map((p, i) => (
            <div class="service-row" style="padding: 26px 0; border-bottom: 1px solid var(--rule)">
              <span style="font-size: clamp(20px, 2.6vw, 25px); font-weight: 500; letter-spacing: -0.015em">{p.t}</span>
              <span style="font-size: 15px; color: var(--dim); line-height: 1.55">{p.d}</span>
              <span class="num" style="font-size: 13px; color: var(--faint); text-align: right">0{i + 1}</span>
            </div>
          ))
        }
      </div>
    </section>

    {/* ROADMAP - three horizons, grounded in the deferral table + open issues */}
    <section class="section">
      <div class="split-head">
        <div>
          <div style="font-size: 13.5px; color: var(--accent); margin-bottom: 18px; letter-spacing: 0.04em">03 - what's next</div>
          <h2 style="font-size: clamp(48px, 6vw, 80px); font-weight: 500; letter-spacing: -0.04em; line-height: 0.92; margin: 0; font-family: var(--font-display)">Roadmap.</h2>
        </div>
        <div style="padding-top: 14px">
          <p style="font-size: 19px; line-height: 1.65; margin: 0">
            The order is deliberately boring: make the core run reliable, wire in the real backends, then add more metadata.
          </p>
          <p style="font-size: 16px; line-height: 1.65; color: var(--dim); margin: 20px 0 0; max-width: 56ch">
            This is still in development, so the order can move. The dependency chain is what matters.
          </p>
        </div>
      </div>

      <div style="border-top: 1px solid var(--rule)">
        {
          roadmap.map((h, i) => (
            <div class="label-row" style="padding: 34px 0; border-bottom: 1px solid var(--rule)">
              <div>
                <div style={`font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; margin-bottom: 10px; color: ${i === 0 ? "var(--accent)" : "var(--dim)"}`}>{h.when}</div>
                <div style="font-size: 21px; font-weight: 500; letter-spacing: -0.015em; color: var(--ink)">{h.title}</div>
                <div style="font-size: 12.5px; color: var(--faint); margin-top: 6px">{h.phase}</div>
              </div>
              <ul style="margin: 0; padding: 0; list-style: none">
                {
                  h.items.map((it, j) => (
                    <li
                      style={`font-size: 16px; line-height: 1.6; color: var(--dim); ${j < h.items.length - 1 ? "padding-bottom: 12px; margin-bottom: 12px; border-bottom: 1px dashed var(--rule)" : ""}`}
                    >
                      {it}
                    </li>
                  ))
                }
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    {/* PROVENANCE - who built it and why, closing the loop to the studio */}
    <section class="section">
      <div class="label-row">
        <div style="font-size: 13.5px; color: var(--dim); padding-top: 4px">Built by</div>
        <div style="max-width: 62ch">
          <p style="font-size: 18px; line-height: 1.65; margin: 0; color: var(--ink)">
            Built at The Studio in Dunkeld by a director of photography who also works as a platform engineer. The tool comes from doing the dailies work, not from trying to invent a new category.
          </p>
          <p style="font-size: 15px; line-height: 1.65; color: var(--dim); margin: 20px 0 0">
            Licensed AGPL-3.0-or-later. The FFmpeg render path lands before the source opens, so a self-hoster can cover everyday codecs without a Resolve licence. Resolve stays optional for RAW. Source opens once it is past v0.1.
          </p>
          <div style="margin-top: 28px; display: flex; gap: 28px; flex-wrap: wrap">
            <a href="/#tools" style="font-size: 15px; color: var(--ink); border-bottom: 1px solid var(--faint); padding-bottom: 2px">All tools</a>
            <a href="mailto:studio@imla.ch" style="font-size: 15px; color: var(--ink); border-bottom: 1px solid var(--faint); padding-bottom: 2px">Talk to us - studio@imla.ch</a>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</Base>
